# ─── Database ─────────────────────────────────────────────────────────────────
# Get this from Supabase → Project Settings → Database → Connection string
DATABASE_URL="postgresql://postgres:[password]@db.[ref].supabase.co:5432/postgres"

# ─── PassKit ──────────────────────────────────────────────────────────────────
# Get from passkit.com → Account → API Keys
PASSKIT_API_KEY=""
PASSKIT_TEMPLATE_ID=""   # create your loyalty card template in PassKit dashboard first

# ─── WhatsApp Business API ─────────────────────────────────────────────────────
# Get from Meta for Developers → WhatsApp → API Setup
WHATSAPP_TOKEN=""        # System user token (permanent token)
WHATSAPP_PHONE_ID=""     # Your WhatsApp Business phone number ID

# ─── App ──────────────────────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# ─── Auth (NextAuth — add when dashboard login is built) ──────────────────────
NEXTAUTH_SECRET=""
NEXTAUTH_URL="http://localhost:3000"
